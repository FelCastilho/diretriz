{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "project": "diretriz-brand-system",
  "description": "Structured catalog of every environment variable detected for the Diretriz Brand System Supabase backend.",
  "generatedAt": "2026-05-25",
  "groups": [
    {
      "name": "supabase_public",
      "description": "Public Supabase config — safe to expose in the Vite client bundle.",
      "variables": [
        { "key": "VITE_SUPABASE_URL", "type": "url", "required": true, "secret": false, "example": "https://YOUR_PROJECT_REF.supabase.co", "exposeToClient": true },
        { "key": "VITE_SUPABASE_ANON_KEY", "type": "string", "required": true, "secret": false, "example": "your-anon-public-key", "exposeToClient": true },
        { "key": "VITE_SUPABASE_PROJECT_REF", "type": "string", "required": true, "secret": false, "example": "YOUR_PROJECT_REF", "exposeToClient": true }
      ]
    },
    {
      "name": "supabase_secret",
      "description": "Server-only Supabase secrets. Bypass RLS / sign JWTs — never ship to the browser.",
      "variables": [
        { "key": "SUPABASE_URL", "type": "url", "required": true, "secret": false, "example": "https://YOUR_PROJECT_REF.supabase.co", "exposeToClient": false },
        { "key": "SUPABASE_ANON_KEY", "type": "string", "required": true, "secret": false, "example": "your-anon-public-key", "exposeToClient": false },
        { "key": "SUPABASE_SERVICE_ROLE_KEY", "type": "string", "required": true, "secret": true, "example": "your-service-role-key", "exposeToClient": false },
        { "key": "SUPABASE_JWT_SECRET", "type": "string", "required": true, "secret": true, "example": "your-jwt-secret", "exposeToClient": false },
        { "key": "SUPABASE_PROJECT_REF", "type": "string", "required": true, "secret": false, "example": "YOUR_PROJECT_REF", "exposeToClient": false }
      ]
    },
    {
      "name": "database",
      "description": "Postgres connection strings for migrations, seeds and server pooling.",
      "variables": [
        { "key": "DATABASE_URL", "type": "uri", "required": true, "secret": true, "example": "postgresql://postgres:[YOUR-PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres", "exposeToClient": false },
        { "key": "DATABASE_POOL_URL", "type": "uri", "required": false, "secret": true, "example": "postgresql://postgres.YOUR_PROJECT_REF:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres", "exposeToClient": false },
        { "key": "POSTGRES_PASSWORD", "type": "string", "required": true, "secret": true, "example": "your-db-password", "exposeToClient": false }
      ]
    },
    {
      "name": "storage",
      "description": "Supabase Storage for uploads (profile photos, brand assets).",
      "variables": [
        { "key": "SUPABASE_STORAGE_URL", "type": "url", "required": false, "secret": false, "example": "https://YOUR_PROJECT_REF.supabase.co/storage/v1", "exposeToClient": false },
        { "key": "STORAGE_BUCKET_AVATARS", "type": "string", "required": false, "secret": false, "default": "avatars", "exposeToClient": true },
        { "key": "STORAGE_BUCKET_BRAND_ASSETS", "type": "string", "required": false, "secret": false, "default": "brand-assets", "exposeToClient": true }
      ]
    },
    {
      "name": "auth",
      "description": "Authentication & SSO — private/SSO pages (e.g. Posicionamento) require it.",
      "variables": [
        { "key": "AUTH_REDIRECT_URL", "type": "url", "required": true, "secret": false, "example": "http://localhost:5173/auth/callback", "exposeToClient": false },
        { "key": "AUTH_SITE_URL", "type": "url", "required": true, "secret": false, "example": "http://localhost:5173", "exposeToClient": false },
        { "key": "SSO_PROVIDER", "type": "enum", "enum": ["saml", "oidc", "google", "azure"], "required": false, "secret": false, "default": "saml", "exposeToClient": false },
        { "key": "SSO_DOMAIN", "type": "string", "required": false, "secret": false, "exposeToClient": false },
        { "key": "GOOGLE_OAUTH_CLIENT_ID", "type": "string", "required": false, "secret": false, "exposeToClient": false },
        { "key": "GOOGLE_OAUTH_CLIENT_SECRET", "type": "string", "required": false, "secret": true, "exposeToClient": false }
      ]
    },
    {
      "name": "ai_assistant",
      "description": "Backs the ⌘K SearchModal AI assistant answers.",
      "variables": [
        { "key": "AI_PROVIDER", "type": "enum", "enum": ["anthropic", "openai"], "required": false, "secret": false, "default": "anthropic", "exposeToClient": false },
        { "key": "ANTHROPIC_API_KEY", "type": "string", "required": false, "secret": true, "exposeToClient": false },
        { "key": "AI_MODEL", "type": "string", "required": false, "secret": false, "default": "claude-opus-4-7", "exposeToClient": false }
      ]
    },
    {
      "name": "share_links",
      "description": "Temporary public share links generated from the Topbar.",
      "variables": [
        { "key": "SHARE_LINK_DEFAULT_TTL_DAYS", "type": "number", "required": false, "secret": false, "default": 14, "exposeToClient": false },
        { "key": "SHARE_LINK_SECRET", "type": "string", "required": false, "secret": true, "exposeToClient": false }
      ]
    },
    {
      "name": "application",
      "description": "General application configuration.",
      "variables": [
        { "key": "APP_ENV", "type": "enum", "enum": ["development", "staging", "production"], "required": false, "secret": false, "default": "development", "exposeToClient": false },
        { "key": "APP_PORT", "type": "number", "required": false, "secret": false, "default": 5173, "exposeToClient": false },
        { "key": "APP_BRAND_NAME", "type": "string", "required": false, "secret": false, "default": "LOGOTIPO", "exposeToClient": true },
        { "key": "APP_DEFAULT_THEME", "type": "enum", "enum": ["dark", "light"], "required": false, "secret": false, "default": "dark", "exposeToClient": true }
      ]
    }
  ]
}
