# ============================================================================
# Diretriz · Brand System — Environment Variables (example)
# ----------------------------------------------------------------------------
# Copy to `.env` (server) and `.env.local` (Vite client) and fill in real
# values. NEVER commit the filled files. Only VITE_-prefixed vars are exposed
# to the browser bundle — keep service/secret keys server-side only.
# ============================================================================

# ─── Supabase · public (safe for the browser / Vite client) ────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
VITE_SUPABASE_PROJECT_REF=YOUR_PROJECT_REF

# ─── Supabase · server-only secrets (NEVER expose to the client) ────────────
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF

# ─── Database (direct / pooled connections, migrations, seeds) ──────────────
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
DATABASE_POOL_URL=postgresql://postgres.YOUR_PROJECT_REF:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres
POSTGRES_PASSWORD=your-db-password

# ─── Supabase Storage (uploads: avatars, brand assets) ──────────────────────
SUPABASE_STORAGE_URL=https://YOUR_PROJECT_REF.supabase.co/storage/v1
STORAGE_BUCKET_AVATARS=avatars
STORAGE_BUCKET_BRAND_ASSETS=brand-assets

# ─── Authentication / SSO (Posicionamento & private pages require SSO) ──────
AUTH_REDIRECT_URL=http://localhost:5173/auth/callback
AUTH_SITE_URL=http://localhost:5173
SSO_PROVIDER=saml
SSO_DOMAIN=
# OAuth (optional providers)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ─── AI Assistant (⌘K SearchModal answer generation) ────────────────────────
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-7

# ─── Share links (Topbar share — temporary public links) ────────────────────
SHARE_LINK_DEFAULT_TTL_DAYS=14
SHARE_LINK_SECRET=change-me

# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=5173
APP_BRAND_NAME=LOGOTIPO
APP_DEFAULT_THEME=dark
